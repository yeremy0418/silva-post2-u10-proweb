{
  "info": {
    "_postman_id": "c2f70e75-1f0e-4e93-8ed7-1d96bc2cc1a4",
    "name": "API ToDoApp",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST crear tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 201 Created\", () => {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Respuesta contiene id numerico\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b).to.have.property(\"id\");",
              "  pm.collectionVariables.set(\"tareaId\", b.id);",
              "});",
              "pm.test(\"Tiempo de respuesta < 500ms\", () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Tarea desde Postman\",\n  \"descripcion\": \"Checkpoint 2\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/tareas"
      },
      "response": []
    },
    {
      "name": "GET obtener tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Id coincide\", () => {",
              "  const b = pm.response.json();",
              "  const id = Number(pm.collectionVariables.get(\"tareaId\"));",
              "  pm.expect(b.id).to.eql(id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/tareas/{{tareaId}}"
      },
      "response": []
    },
    {
      "name": "PATCH completar tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Tarea completada\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.completada).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [],
        "url": "{{baseUrl}}/api/tareas/{{tareaId}}/completar"
      },
      "response": []
    },
    {
      "name": "GET verificar completada",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Completada en true\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.completada).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/tareas/{{tareaId}}"
      },
      "response": []
    },
    {
      "name": "GET tarea inexistente (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 404 Not Found\", () => {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/tareas/999999"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "tareaId",
      "value": ""
    }
  ]
}
